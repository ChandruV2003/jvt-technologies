<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.jvt.watchdog</string>
  <key>ProgramArguments</key>
  <array>
    <string>/Users/c.s.d.v.r.s./Developer/Control-Host/JVT-Technologies/ops/watchdog/run_watchdog.sh</string>
  </array>
  <key>StartInterval</key>
  <integer>900</integer>
  <key>RunAtLoad</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/Users/c.s.d.v.r.s./Developer/Control-Host/JVT-Technologies/ops/watchdog/state/watchdog.stdout.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/c.s.d.v.r.s./Developer/Control-Host/JVT-Technologies/ops/watchdog/state/watchdog.stderr.log</string>
</dict>
</plist>
