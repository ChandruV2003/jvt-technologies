# Backend
APP_NAME=private-doc-intel-demo
APP_ENV=development
API_HOST=127.0.0.1
API_PORT=8000
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Retrieval
EMBEDDING_PROVIDER=fastembed-local
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
ANSWER_PROVIDER=extractive
ANSWER_MODEL_NAME=
LOCAL_ANSWER_MODEL_NAME=mlx-community/Qwen2.5-1.5B-Instruct-4bit
LOCAL_ANSWER_MAX_TOKENS=280
LOCAL_ANSWER_TEMPERATURE=0.2
ANSWER_API_BASE_URL=
ANSWER_API_KEY=
ANSWER_API_TIMEOUT_SECONDS=30
LOCAL_MODEL_RUNTIME=mlx-lm
VECTOR_BACKEND=sqlite-fts5
VECTOR_COLLECTION=documents

# Storage
STORAGE_ROOT=data
VECTOR_DATA_ROOT=
UPLOADS_DIR_NAME=uploads
DATABASE_FILENAME=doc_intel.sqlite3
CHUNK_SIZE=800
CHUNK_OVERLAP=120
RETRIEVAL_TOP_K=5
LOCAL_MODEL_CONFIG_DIR=config/model-profiles
MODEL_ARTIFACT_ROOT=~/Library/Caches/Private-AI-Lab/models
EMBEDDING_CACHE_ROOT=
ANSWER_MODEL_CACHE_ROOT=
