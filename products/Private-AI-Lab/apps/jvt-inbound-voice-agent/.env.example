# Default JVT path: local reasoning through the model router.
JVT_VOICE_RESPONSE_ENGINE=local-model-router
JVT_MODEL_ROUTER_URL=http://127.0.0.1:8760

# Optional alternate path only if explicitly approved.
# OPENAI_API_KEY=
# OPENAI_REALTIME_MODEL=gpt-realtime
# OPENAI_REALTIME_VOICE=marin

# Required only after a local realtime audio bridge is implemented/configured.
JVT_VOICE_LOCAL_AUDIO_BRIDGE_READY=0
JVT_VOICE_LOCAL_AUDIO_BRIDGE_URL=ws://127.0.0.1:8761/twilio-media
JVT_VOICE_LOCAL_AUDIO_BRIDGE_HEALTH_URL=http://127.0.0.1:8761/health

# Use dry run until a real public webhook and phone provider are configured.
JVT_VOICE_DRY_RUN=1
JVT_VOICE_PUBLIC_BASE_URL=https://your-public-voice-host.example.com
JVT_VOICE_PHONE_PROVIDER_CONFIGURED=0
JVT_VOICE_ALLOWED_HOSTS=
JVT_VOICE_PORT=8066
